# DESTINAZIONE: tests/.env.test.example
# Copia questo file come tests/.env.test e riempilo con i tuoi valori.
# NON committare tests/.env.test — è già in .gitignore.
#
# Queste variabili vengono lette da tests/global-setup.ts
# e dai file di test tramite process.env.

# URL del server Next.js su cui girare i test
# Dev locale: http://localhost:3000
# Staging:    https://staging.geekore.it
BASE_URL=http://localhost:3000

# Credenziali dell'utente di test
# Deve esistere già nel tuo Supabase (o verrà creato automaticamente)
TEST_EMAIL=e2e@geekore.it
TEST_PASSWORD=GeekoreE2E2024!
TEST_USERNAME=e2e_testuser

# Opzionale: DB Supabase separato per i test (consigliato in CI)
# Se omesso, usa le variabili NEXT_PUBLIC_* del progetto
# TEST_SUPABASE_URL=https://xxx.supabase.co
# TEST_SUPABASE_ANON_KEY=eyJ...
