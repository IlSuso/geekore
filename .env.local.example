# ======================
# Supabase (Obbligatorie)
# ======================
NEXT_PUBLIC_SUPABASE_URL=your_supabase_project_url
NEXT_PUBLIC_SUPABASE_ANON_KEY=your_supabase_anon_key
SUPABASE_SERVICE_ROLE_KEY=your_supabase_service_role_key

# ======================
# Dominio del sito (Obbligatoria in produzione)
# ======================
# Usato per Steam OAuth callback. In locale: http://localhost:3000
NEXT_PUBLIC_SITE_URL=https://geekore.it

# ======================
# API Esterne (Opzionali per ora)
# ======================
# Steam (per importare giochi, ore giocate, ecc.)
STEAM_API_KEY=your_steam_api_key_here

# IGDB (per raccomandazioni e news sui videogiochi)
IGDB_CLIENT_ID=your_igdb_client_id
IGDB_CLIENT_SECRET=your_igdb_client_secret

# TMDB (per raccomandazioni film/serie/anime)
TMDB_API_KEY=your_tmdb_bearer_token

# DeepL (per tradurre descrizioni di giochi, manga, boardgame in italiano)
# Chiave gratuita su https://www.deepl.com/pro-api — 500.000 char/mese gratis
# Le chiavi free finiscono con ":fx"
DEEPL_API_KEY=your_deepl_api_key_here

# AniList (non serve chiave, ma puoi mettere qui se vuoi)
# NEXT_PUBLIC_ANILIST_CLIENT_ID=